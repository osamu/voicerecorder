<?xml version="1.0" encoding="utf-8"?>
<!--
  録音・DB・トークンをクラウド/デバイス間バックアップから除外する。
  録音データや OAuth トークンが端末外へ複製されないようにするため、
  内部ストレージ全体をバックアップ・移行の対象外とする。
-->
<data-extraction-rules>
    <cloud-backup>
        <exclude domain="file" />
        <exclude domain="database" />
        <exclude domain="sharedpref" />
        <exclude domain="external" />
    </cloud-backup>
    <device-transfer>
        <exclude domain="file" />
        <exclude domain="database" />
        <exclude domain="sharedpref" />
        <exclude domain="external" />
    </device-transfer>
</data-extraction-rules>
